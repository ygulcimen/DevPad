<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevPad.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="DevPad.Views.JwtToolView"
             x:DataType="vm:JwtToolViewModel">

    <UserControl.Styles>
        <!-- Section card styling -->
        <Style Selector="Border.Section">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888888"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ── Toolbar ───────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#252526"
                BorderBrush="#3C3C3C"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <StackPanel Classes="Toolbar" Orientation="Horizontal" Spacing="6">
                <Button Command="{Binding DecodeCommand}">Decode</Button>
                <Border Width="1" Background="#3C3C3C" Margin="4,2"/>
                <Button Classes="primary" Command="{Binding CopyPayloadCommand}" Content="{Binding CopyPayloadButtonText}"/>
                <Button Command="{Binding CopyHeaderCommand}"  Content="{Binding CopyHeaderButtonText}"/>
                <Button Command="{Binding SaveAsCommand}">Save As</Button>
                <Border Width="1" Background="#3C3C3C" Margin="4,2"/>
                <Button Classes="danger" Command="{Binding ClearCommand}">Clear</Button>
            </StackPanel>
        </Border>

        <!-- ── Pane labels ────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="#1C1C1C"
                BorderBrush="#3C3C3C"
                BorderThickness="0,0,0,1"
                Height="22">
            <Grid ColumnDefinitions="*,4,*">
                <TextBlock Grid.Column="0"
                           Text="TOKEN"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"
                           Padding="12,0"/>
                <TextBlock Grid.Column="2"
                           Text="DECODED"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"
                           Padding="12,0"/>
            </Grid>
        </Border>

        <!-- ── Split pane ─────────────────────────────────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="*,4,*">

            <!-- Input TextBox -->
            <TextBox Grid.Column="0"
                     Text="{Binding InputText}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="{StaticResource MonospaceFont}"
                     FontSize="13"
                     Background="#1E1E1E"
                     Foreground="#D4D4D4"
                     CaretBrush="#D4D4D4"
                     SelectionBrush="#264F78"
                     BorderThickness="0"
                     Padding="12,8"
                     VerticalAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Watermark="Paste JWT here (eyJ...)"/>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Background="#3C3C3C"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"/>

            <!-- Right panel: decoded sections or empty hint -->
            <Grid Grid.Column="2" Background="#1E1E1E">

                <!-- Empty-state hint -->
                <TextBlock Text="Decoded sections will appear here"
                           FontSize="13"
                           Foreground="#444444"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding HasNoResult}"/>

                <!-- Decoded output -->
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding HasResult}"
                              Padding="10">
                    <StackPanel Spacing="10">

                        <!-- ── Header section ── -->
                        <Border Classes="Section">
                            <Grid RowDefinitions="Auto,Auto">
                                <!-- Section label + meta -->
                                <Border Grid.Row="0"
                                        Padding="10,7"
                                        BorderBrush="#3C3C3C"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Classes="SectionHeader" Text="HEADER"/>
                                        <TextBlock Text="{Binding AlgorithmText}"
                                                   FontSize="11"
                                                   Foreground="#9CDCFE"/>
                                        <TextBlock Text="{Binding TokenTypeText}"
                                                   FontSize="11"
                                                   Foreground="#9CDCFE"/>
                                    </StackPanel>
                                </Border>
                                <TextBox Grid.Row="1"
                                         Text="{Binding HeaderText}"
                                         IsReadOnly="True"
                                         FontFamily="{StaticResource MonospaceFont}"
                                         FontSize="12"
                                         Background="Transparent"
                                         Foreground="#D4D4D4"
                                         BorderThickness="0"
                                         Padding="10,8"
                                         TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- ── Payload section ── -->
                        <Border Classes="Section">
                            <Grid RowDefinitions="Auto,Auto">
                                <Border Grid.Row="0"
                                        Padding="10,7"
                                        BorderBrush="#3C3C3C"
                                        BorderThickness="0,0,0,1">
                                    <TextBlock Classes="SectionHeader" Text="PAYLOAD"/>
                                </Border>
                                <TextBox Grid.Row="1"
                                         Text="{Binding PayloadText}"
                                         IsReadOnly="True"
                                         FontFamily="{StaticResource MonospaceFont}"
                                         FontSize="12"
                                         Background="Transparent"
                                         Foreground="#D4D4D4"
                                         BorderThickness="0"
                                         Padding="10,8"
                                         TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- ── Signature section ── -->
                        <Border Classes="Section" Padding="10,8">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="SectionHeader" Text="SIGNATURE"/>
                                <TextBlock Text="{Binding AlgorithmText}"
                                           FontFamily="{StaticResource MonospaceFont}"
                                           FontSize="12"
                                           Foreground="#CCCCCC"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="Cannot verify — secret/public key not available"
                                           FontSize="12"
                                           Foreground="#CCA700"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Expiry section ── -->
                        <Border Classes="Section" Padding="10,8">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="SectionHeader" Text="EXPIRY"/>
                                <TextBlock Text="{Binding ExpiryText}"
                                           FontFamily="{StaticResource MonospaceFont}"
                                           FontSize="12"
                                           Foreground="{Binding ExpiryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>

        <!-- ── Status bar ──────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="#252526"
                BorderBrush="#3C3C3C"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#8E8E8E"
                       FontSize="12"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</UserControl>
