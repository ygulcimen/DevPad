<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevPad.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="DevPad.Views.Base64ToolView"
             x:DataType="vm:Base64ToolViewModel">

    <UserControl.Styles>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ── Toolbar ───────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#252526"
                BorderBrush="#3C3C3C"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Left: operation buttons -->
                <StackPanel Classes="Toolbar"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="6">
                    <Button Command="{Binding EncodeCommand}">Encode</Button>
                    <Button Command="{Binding DecodeCommand}">Decode</Button>
                    <Button Command="{Binding SwapCommand}">Swap</Button>
                    <Border Width="1" Background="#3C3C3C" Margin="4,2"/>
                    <Button Classes="primary" Command="{Binding CopyCommand}" Content="{Binding CopyButtonText}"/>
                    <Button Command="{Binding SaveAsCommand}">Save As</Button>
                    <Button Classes="danger" Command="{Binding ClearCommand}">Clear</Button>
                </StackPanel>

                <!-- Right: URL-safe toggle -->
                <CheckBox Grid.Column="1"
                          IsChecked="{Binding IsUrlSafe}"
                          Margin="12,0,0,0">
                    URL-safe
                </CheckBox>

            </Grid>
        </Border>

        <!-- ── Pane labels ────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="#1C1C1C"
                BorderBrush="#3C3C3C"
                BorderThickness="0,0,0,1"
                Height="22">
            <Grid ColumnDefinitions="*,4,*">
                <TextBlock Grid.Column="0"
                           Text="INPUT"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"
                           Padding="12,0"/>
                <TextBlock Grid.Column="2"
                           Text="OUTPUT"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#4A4A4A"
                           VerticalAlignment="Center"
                           Padding="12,0"/>
            </Grid>
        </Border>

        <!-- ── Split pane ─────────────────────────────────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="*,4,*">

            <!-- Input TextBox -->
            <TextBox Grid.Column="0"
                     Text="{Binding InputText}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="{StaticResource MonospaceFont}"
                     FontSize="13"
                     Background="#1E1E1E"
                     Foreground="#D4D4D4"
                     CaretBrush="#D4D4D4"
                     SelectionBrush="#264F78"
                     BorderThickness="0"
                     Padding="12,8"
                     VerticalAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Watermark="Input text or Base64 here..."/>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Background="#3C3C3C"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"/>

            <!-- Output TextBox (read-only result) -->
            <TextBox Grid.Column="2"
                     Text="{Binding OutputText}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="{StaticResource MonospaceFont}"
                     FontSize="13"
                     Background="#1A1A1A"
                     Foreground="#D4D4D4"
                     SelectionBrush="#264F78"
                     BorderThickness="0"
                     Padding="12,8"
                     VerticalAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Watermark="Output appears here after Encode or Decode"/>

        </Grid>

        <!-- ── Status bar ──────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="#252526"
                BorderBrush="#3C3C3C"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#808080"
                       FontSize="12"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</UserControl>
