<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevPad.ViewModels"
             xmlns:models="using:DevPad.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="DevPad.Views.JsonToolView"
             x:DataType="vm:JsonToolViewModel">

    <UserControl.Styles>
        <Style Selector="Button.Tab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7d8590"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.Tab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#e6edf3"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Toolbar ───────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#161b22"
                BorderBrush="#30363d"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <StackPanel Classes="Toolbar" Orientation="Horizontal" Spacing="6">
                <Button Command="{Binding MinifyCommand}">Minify</Button>
                <Border Width="1" Background="#30363d" Margin="4,2"/>
                <Button Command="{Binding CopyCommand}"          Content="{Binding CopyButtonText}"/>
                <Button Classes="primary" Command="{Binding CopyFormattedCommand}" Content="{Binding CopyOutputButtonText}"/>
                <Button Command="{Binding SaveAsCommand}">Save As</Button>
                <Button Classes="danger" Command="{Binding ClearCommand}">Clear</Button>
            </StackPanel>
        </Border>

        <!-- ── Split pane (Input 35% │ Output 65%) ───────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="0.35*,4,0.65*">

            <!-- ── Left: INPUT ───────────────────────────────────── -->
            <Grid Grid.Column="0" RowDefinitions="22,*">

                <!-- Pane label -->
                <Border Grid.Row="0"
                        Background="#161b22"
                        BorderBrush="#3C3C3C"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="INPUT"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#7d8590"
                               VerticalAlignment="Center"
                               Padding="12,0"/>
                </Border>

                <TextBox Grid.Row="1"
                         Text="{Binding InputText}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="{StaticResource MonospaceFont}"
                         FontSize="13"
                         Background="#0d1117"
                         Foreground="#e6edf3"
                         CaretBrush="#e6edf3"
                         SelectionBrush="#264F78"
                         BorderThickness="0"
                         Padding="12,8"
                         VerticalAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Watermark="Paste JSON here..."/>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Background="#30363d"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"/>

            <!-- ── Right: OUTPUT ──────────────────────────────────── -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*" Background="#0d1117">

                <!-- Tab bar: TEXT | TREE -->
                <Border Grid.Row="0"
                        Background="#252526"
                        BorderBrush="#3C3C3C"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">

                        <!-- TEXT tab -->
                        <StackPanel Orientation="Vertical" Spacing="0">
                            <Button Classes="Tab"
                                    Command="{Binding SwitchToTextCommand}">TEXT</Button>
                            <Border Height="2"
                                    Background="#58a6ff"
                                    IsVisible="{Binding ShowFormatted}"/>
                        </StackPanel>

                        <!-- TREE tab -->
                        <StackPanel Orientation="Vertical" Spacing="0">
                            <Button Classes="Tab"
                                    Command="{Binding SwitchToTreeCommand}">TREE</Button>
                            <Border Height="2"
                                    Background="#58a6ff"
                                    IsVisible="{Binding ShowTree}"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ── Formatted-text panel (default) ────────────── -->
                <Grid Grid.Row="1" IsVisible="{Binding ShowFormatted}" Background="#0d1117">

                    <TextBlock x:Name="FormattedEmptyHint"
                               Text="Formatted output appears once valid JSON is entered"
                               FontSize="13"
                               Foreground="#4a5568"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="32"/>

                    <ScrollViewer x:Name="OutputScroller"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  IsVisible="False"
                                  Padding="0,4">
                        <!-- Each line is one TextBlock added by code-behind -->
                        <StackPanel x:Name="OutputLines"
                                    Spacing="0"
                                    Margin="4,0"/>
                    </ScrollViewer>

                </Grid>

                <!-- ── Tree panel ─────────────────────────────────── -->
                <Grid Grid.Row="1" IsVisible="{Binding ShowTree}" Background="#0d1117">

                    <TextBlock Text="Tree view appears here once valid JSON is entered"
                               FontSize="13"
                               Foreground="#4a5568"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="32"
                               IsVisible="{Binding IsInvalid}"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding IsValid}"
                                  Padding="4">
                        <TreeView ItemsSource="{Binding TreeNodes}"
                                  FontFamily="{StaticResource MonospaceFont}"
                                  FontSize="13">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate x:DataType="models:JsonTreeNode"
                                                  ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Spacing="0">
                                        <TextBlock Text="{Binding KeyDisplay}"
                                                   Foreground="#9CDCFE"/>
                                        <TextBlock Text="{Binding ValueDisplay}"
                                                   Foreground="{Binding ValueForeground}"/>
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>

                </Grid>

            </Grid>
        </Grid>

        <!-- ── Status bar ──────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#161b22"
                BorderBrush="#30363d"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">

                <TextBlock Text="{Binding StatusText}"
                           Foreground="{Binding StatusForeground}"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <TextBlock Text="·"
                           Foreground="#555555"
                           FontSize="12"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsValid}"/>
                <TextBlock Text="{Binding NodeCountText}"
                           Foreground="#808080"
                           FontSize="12"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsValid}"/>

                <TextBlock Text="·"
                           Foreground="#555555"
                           FontSize="12"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsValid}"/>
                <TextBlock Text="{Binding FileSizeText}"
                           Foreground="#808080"
                           FontSize="12"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsValid}"/>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
