<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DevPad.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="DevPad.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DevPad"
        Icon="avares://DevPad/Assets/devpad.ico"
        Width="1200"
        Height="700"
        MinWidth="800"
        MinHeight="500"
        Background="#0d1117">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Shift+V" Command="{Binding GlobalPasteAndFormatCommand}"/>
        <KeyBinding Gesture="Ctrl+D1"      Command="{Binding SelectTool1Command}"/>
        <KeyBinding Gesture="Ctrl+D2"      Command="{Binding SelectTool2Command}"/>
        <KeyBinding Gesture="Ctrl+D3"      Command="{Binding SelectTool3Command}"/>
        <KeyBinding Gesture="Ctrl+D4"      Command="{Binding SelectTool4Command}"/>
        <KeyBinding Gesture="Ctrl+D5"      Command="{Binding SelectTool5Command}"/>
        <KeyBinding Gesture="Ctrl+L"       Command="{Binding GlobalClearCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding GlobalCopyOutputCommand}"/>
    </Window.KeyBindings>

    <Grid ColumnDefinitions="260,*">
        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBackground}"
                BorderBrush="#30363d"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">

                <!-- App Title -->
                <Border Grid.Row="0"
                        Padding="20,22,16,18"
                        BorderBrush="#30363d"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="&lt;/&gt;"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource MonospaceFont}"
                                   Foreground="#58a6ff"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="DevPad"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#e6edf3"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Tool List -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Tools}"
                         SelectedItem="{Binding SelectedTool}"
                         Background="Transparent"
                         Padding="10,10,10,10">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding"       Value="12,10"/>
                            <Setter Property="Margin"        Value="0,2"/>
                            <Setter Property="CornerRadius"  Value="6"/>
                            <Setter Property="Cursor"        Value="Hand"/>
                            <Setter Property="BorderThickness" Value="2,0,0,0"/>
                            <Setter Property="BorderBrush"   Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="{StaticResource SidebarItemHover}"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="{StaticResource SidebarItemSelected}"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="BorderBrush" Value="#58a6ff"/>
                        </Style>
                        <!-- Default icon / label colours -->
                        <Style Selector="ListBoxItem PathIcon">
                            <Setter Property="Foreground" Value="#7d8590"/>
                        </Style>
                        <Style Selector="ListBoxItem TextBlock">
                            <Setter Property="Foreground" Value="#7d8590"/>
                        </Style>
                        <!-- Selected: icon and label light up -->
                        <Style Selector="ListBoxItem:selected PathIcon">
                            <Setter Property="Foreground" Value="#e6edf3"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected TextBlock">
                            <Setter Property="Foreground" Value="#e6edf3"/>
                        </Style>
                    </ListBox.Styles>

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ToolViewModelBase">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <PathIcon Data="{Binding IconPath}"
                                          Width="18"
                                          Height="18"/>
                                <TextBlock Text="{Binding ToolName}"
                                           VerticalAlignment="Center"
                                           FontSize="14"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1"
                Background="#0d1117">
            <ContentControl Content="{Binding SelectedTool}"/>
        </Border>
    </Grid>
</Window>
