<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DevPad.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="DevPad.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DevPad"
        Icon="avares://DevPad/Assets/devpad.ico"
        Width="1200"
        Height="700"
        MinWidth="800"
        MinHeight="500"
        Background="#252526">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.KeyBindings>
        <!-- Global paste-and-format: reads clipboard and delegates to the active tool -->
        <KeyBinding Gesture="Ctrl+Shift+V" Command="{Binding GlobalPasteAndFormatCommand}"/>
    </Window.KeyBindings>

    <Grid ColumnDefinitions="200,*">
        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBackground}"
                BorderBrush="#3C3C3C"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <!-- App Title -->
                <Border Grid.Row="0"
                        Padding="16,20,16,16"
                        BorderBrush="#3C3C3C"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="DevPad"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#E0E0E0"/>
                </Border>

                <!-- Tool List -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Tools}"
                         SelectedItem="{Binding SelectedTool}"
                         Background="Transparent"
                         Padding="8,8,8,8">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="CornerRadius" Value="6"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="{StaticResource SidebarItemHover}"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="{StaticResource SidebarItemSelected}"/>
                        </Style>
                        <!-- Default icon / label colours -->
                        <Style Selector="ListBoxItem PathIcon">
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                        </Style>
                        <Style Selector="ListBoxItem TextBlock">
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                        </Style>
                        <!-- Selected state: icon and label light up to white -->
                        <Style Selector="ListBoxItem:selected PathIcon">
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected TextBlock">
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Style>
                    </ListBox.Styles>

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ToolViewModelBase">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <!-- Tool Icon -->
                                <PathIcon Data="{Binding IconPath}"
                                          Width="20"
                                          Height="20"/>
                                <!-- Tool Name -->
                                <TextBlock Text="{Binding ToolName}"
                                           VerticalAlignment="Center"
                                           FontSize="14"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1"
                Background="#1E1E1E">
            <ContentControl Content="{Binding SelectedTool}"/>
        </Border>
    </Grid>
</Window>
